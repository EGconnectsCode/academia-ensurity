{
  "version": 2,
  "name": "academia-ensurity",
  "rewrites": [
    { "source": "/",                  "destination": "/academia-ensurity.html" },
    { "source": "/allstate",          "destination": "/modules/allstate/allstate-academy.html" },
    { "source": "/american-amicable", "destination": "/modules/american-amicable/american-amicable.html" },
    { "source": "/cica",              "destination": "/modules/cica/cica-citizens-v2.html" },
    { "source": "/admin",             "destination": "/admin/admin-panel.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/shared/supabase-config.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
